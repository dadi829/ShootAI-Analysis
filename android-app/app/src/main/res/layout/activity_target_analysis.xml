<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 靶面分析"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="16dp" />

        <!-- 服务器地址 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务器地址"
                android:textSize="14sp"
                android:textColor="#666"
                android:layout_marginBottom="4dp" />
            <EditText
                android:id="@+id/et_server_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="http://your-server.com:3002"
                android:inputType="textUri"
                android:background="@android:color/white"
                android:padding="12dp" />
        </LinearLayout>

        <!-- 文件夹状态 -->
        <TextView
            android:id="@+id/tv_folder_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="未选择文件夹"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginBottom="12dp" />

        <!-- 选择文件夹按钮 -->
        <Button
            android:id="@+id/btn_select_folder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📁 选择文件夹"
            android:textSize="14sp"
            android:backgroundTint="#FF9800"
            android:textColor="#ffffff"
            android:layout_marginBottom="8dp" />

        <!-- 分析按钮 -->
        <Button
            android:id="@+id/btn_analyze"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="开始分析"
            android:textSize="16sp"
            android:backgroundTint="#2196F3"
            android:textColor="#ffffff"
            android:layout_marginBottom="12dp"
            android:enabled="false" />

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="准备就绪"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- ================= 结果显示区域 ================ -->

        <!-- 射击数据卡片 -->
        <LinearLayout
            android:id="@+id/card_metadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 射击数据"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="16dp" />

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="枪型:"
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_firearm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="#E3F2FD"
                        android:textColor="#2196F3"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="射击距离:"
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="#E3F2FD"
                        android:textColor="#2196F3"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="着弹环数:"
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_ring"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="18sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="#FFEBEE"
                        android:textColor="#F44336"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="水平坐标:"
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_h_coord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="#F3E5F5"
                        android:textColor="#9C27B0"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="垂直坐标:"
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_v_coord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="#F3E5F5"
                        android:textColor="#9C27B0"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="偏离靶心:"
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_deviation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:background="#FFF3E0"
                        android:textColor="#FF9800"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </GridLayout>

            <!-- 置信度 -->
            <LinearLayout
                android:id="@+id/layout_confidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="分析置信度:"
                    android:textSize="14sp"
                    android:textColor="#999" />
                <ProgressBar
                    android:id="@+id/progress_confidence"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="#2196F3" />
                <TextView
                    android:id="@+id/tv_confidence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="14sp"
                    android:textColor="#666"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- 整体评价卡片 -->
        <LinearLayout
            android:id="@+id/card_overall"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯 整体评价"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 分数圆 -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginEnd="16dp">
                    <ProgressBar
                        android:id="@+id/progress_score"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#2196F3"
                        android:secondaryProgressTint="#E3F2FD"
                        android:rotation="-90" />
                    <TextView
                        android:id="@+id/tv_score"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="0/10"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- 评价内容 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:textColor="#333"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp" />

                    <!-- 优势点 -->
                    <LinearLayout
                        android:id="@+id/layout_strengths"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅ 优势点:"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#4CAF50" />

                        <LinearLayout
                            android:id="@+id/container_strengths"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 轨迹分析卡片 -->
        <LinearLayout
            android:id="@+id/card_trajectory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍 轨迹分析"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="16dp" />

            <!-- 完整瞄准轨迹 -->
            <LinearLayout
                android:id="@+id/section_pre_full"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="#f9f9f9"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_pre_full_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔴 完整瞄准轨迹 - 状态"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/layout_pre_full_advantages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="优势:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50" />
                    <LinearLayout
                        android:id="@+id/container_pre_full_adv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_pre_full_issues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="问题:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F44336" />
                    <LinearLayout
                        android:id="@+id/container_pre_full_issues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- 击发前0.5秒 -->
            <LinearLayout
                android:id="@+id/section_pre_05"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="#f9f9f9"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_pre_05_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔵 击发前0.5秒 - 状态"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/layout_pre_05_advantages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="优势:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50" />
                    <LinearLayout
                        android:id="@+id/container_pre_05_adv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_pre_05_issues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="问题:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F44336" />
                    <LinearLayout
                        android:id="@+id/container_pre_05_issues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- 击发后复位 -->
            <LinearLayout
                android:id="@+id/section_post"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:background="#f9f9f9"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_post_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 击发后复位 - 状态"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/layout_post_advantages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="优势:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#4CAF50" />
                    <LinearLayout
                        android:id="@+id/container_post_adv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_post_issues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="问题:"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#F44336" />
                    <LinearLayout
                        android:id="@+id/container_post_issues"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="16dp" />
                </LinearLayout>

            </LinearLayout>

            <!-- 偏差分析 -->
            <LinearLayout
                android:id="@+id/section_deviation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#f9f9f9"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 偏差分析"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="偏差方向: "
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_deviation_direction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="14sp"
                        android:background="#E3F2FD"
                        android:textColor="#2196F3"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="根本原因: "
                        android:textSize="14sp"
                        android:textColor="#666" />
                    <TextView
                        android:id="@+id/tv_deviation_cause"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="--"
                        android:textSize="14sp"
                        android:textColor="#333" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 扳机分析卡片 -->
        <LinearLayout
            android:id="@+id/card_trigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎛️ 扳机压力分析"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="控制评分: "
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tv_trigger_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/10"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="4dp"
                    android:background="#E3F2FD"
                    android:textColor="#2196F3" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="曲线特征: "
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_curve_features"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textColor="#333"
                android:layout_marginTop="4dp" />

            <!-- 关键问题 -->
            <LinearLayout
                android:id="@+id/layout_trigger_issues"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="关键问题:"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <LinearLayout
                    android:id="@+id/container_trigger_issues"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="16dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- 改进建议卡片 -->
        <LinearLayout
            android:id="@+id/card_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💪 改进建议"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/container_suggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

        <!-- 备用：简单文本显示 -->
        <TextView
            android:id="@+id/tv_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#333"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
